{
  "name": "trim",
  "version": "1.0.0",
  "description": "A Spotlight-like launcher for Windows and macOS",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node launch.js",
    "kill": "node scripts/kill.js",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "6A31",
  "repository": {
    "type": "git",
    "url": "https://github.com/6A31/trim.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@highlightjs/cdn-assets": "^11.11.1",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.trim.launcher",
    "productName": "Trim",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "extraResources": [
      {
        "from": "scripts/",
        "to": "scripts/",
        "filter": [
          "**/*.ps1"
        ]
      }
    ]
  }
}
